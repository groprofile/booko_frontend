# API base URL for the web app (admin + partner + customer pages).
# VITE_ vars are inlined into the client bundle at build time — public, not secret.
VITE_API_BASE_URL=https://backend-bokko1.onrender.com/api/v1

# For local development against a locally running backend, comment the line
# above and uncomment this one:
# VITE_API_BASE_URL=http://localhost:3000/api/v1
